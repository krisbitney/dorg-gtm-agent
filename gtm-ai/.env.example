# ── Mastra Server ────────────────────────────────────
MASTRA_HOST=0.0.0.0
MASTRA_PORT=4111
MASTRA_LOG_LEVEL=info
MASTRA_STORAGE_URL=file:./mastra.db
MASTRA_OBSERVABILITY_DB_PATH=./mastra-observability.db
MASTRA_CLOUD_ACCESS_TOKEN=your-mastra-cloud-token

# ── Models ────────────────────────────────────────────
GTM_SMALL_MODEL=ollama-cloud/gemma3:31b
GTM_ANALYSIS_MODEL=ollama-cloud/gemma4:31b
GTM_SEARCH_TERM_MODEL=ollama-cloud/gemma4:31b
GTM_SEARCH_FILTER_MODEL=ollama-cloud/gemma3:31b

# ── External APIs ─────────────────────────────────────
OLLAMA_API_KEY=your-api-key
SERPER_API_KEY=your-serper-api-key
CONTEXT_DEV_API_KEY=your-context-dev-api-key

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
URLS_DEDUP_KEY=gtm:urls_dedup
