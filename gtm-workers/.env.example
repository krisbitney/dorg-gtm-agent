# ── API Server ───────────────────────────────────────
WORKERS_API_HOST=0.0.0.0
WORKERS_API_PORT=3000

# ── Database & Redis ─────────────────────────────────
DATABASE_URL=postgres://user:password@localhost:5432/gtm
REDIS_URL=redis://localhost:6379

# ── dOrg API ─────────────────────────────────────────
DORG_API_TOKEN=your-dorg-api-token
DORG_API_BASE_URL=https://agentsofdorg.tech/api

# ── GTM AI Client ────────────────────────────────────
GTM_AI_BASE_URL=http://localhost:4111
GTM_AI_REQUEST_TIMEOUT_MS=600000
GTM_AI_MAX_RETRIES=3
GTM_AI_RETRY_BASE_DELAY_MS=1000
GTM_AI_RETRY_MAX_DELAY_MS=10000
LEAD_SCORE_THRESHOLD=0.5

# ── Queue & Storage Keys ─────────────────────────────
QUEUE_NAME=gtm:posts:queue
QUEUE_PROCESSING_NAME=gtm:posts:processing
QUEUE_DLQ_NAME=gtm:posts:dlq
PROCESSED_URLS_KEY=gtm:processed_urls
SEARCH_TERM_DEDUP_PREFIX=gtm:search_term:
SEARCH_TERM_DEDUP_TTL_SECONDS=86400
URLS_DEDUP_KEY=gtm:urls_dedup

# ── Lead Worker ───────────────────────────────────────────
LEAD_WORKER_CONCURRENCY=1
WORKER_POLL_TIMEOUT_MS=30000
WORKER_REQUEUE_STALE_ON_STARTUP=true

# ── Search Worker ───────────────────────────────────────────
SEARCH_WORKER_CONCURRENCY=1
SEARCH_TERMS_GENERATION_COUNT=50
SEARCH_DAYS_BACK=7
SEARCH_PAGES=1
SEARCH_LOOP_DELAY_MS=5000
SEARCH_QUEUE_MAX_SIZE=50