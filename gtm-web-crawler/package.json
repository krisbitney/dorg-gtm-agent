{
    "name": "gtm-web-crawler",
    "version": "0.0.1",
    "type": "module",
    "description": "GTM Web Crawler for finding leads in Reddit subreddits.",
    "dependencies": {
        "apify": "^3.7.0",
        "apify-cli": "^1.4.1",
        "camoufox-js": "^0.9.3",
        "cheerio": "^1.2.0",
        "crawlee": "^3.16.0",
        "drizzle-orm": "^0.45.2",
        "playwright": "^1.58.2",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/node": "^24.0.0",
        "bun": "^1.3.12",
        "drizzle-kit": "^0.24.2",
        "typescript": "^5.7.3",
        "wait-on": "^9.0.5"
    },
    "scripts": {
        "start": "bun run src/main.ts",
        "start:dev": "bun run src/main.ts",
        "start:prod": "bun run dist/main.js",
        "build": "bun build src/main.ts --outdir ./dist --target bun --packages external",
        "test": "bun run docker:up && wait-on tcp:5342 && wait-on tcp:4111 && bun test && bun run docker:down",
        "docker:up": "docker compose -f docker-compose.test.yml up --detach",
        "docker:down": "docker compose -f docker-compose.test.yml down",
        "get-binaries": "bunx camoufox-js fetch",
        "postinstall": "bun run get-binaries"
    },
    "license": "ISC"
}
