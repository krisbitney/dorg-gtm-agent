# GTM Workers Environment Variables

# API Server
WORKERS_API_HOST=0.0.0.0
WORKERS_API_PORT=3000
WORKERS_PUBLIC_BASE_URL=https://your-public-url.com

# Authentication
TRIGGER_API_TOKEN=your-internal-trigger-token
APIFY_WEBHOOK_SECRET=your-apify-webhook-secret

# Database & Redis
DATABASE_URL=postgres://user:password@localhost:5432/gtm_workers
REDIS_URL=redis://localhost:6379

# dOrg API
DORG_API_TOKEN=your-dorg-api-token
DORG_API_BASE_URL=https://agentsofdorg.tech/api

# Apify
APIFY_TOKEN=your-apify-token
APIFY_RUN_TIMEOUT_SECONDS=3600

# GTM AI
GTM_AI_BASE_URL=http://localhost:4111
GTM_AI_REQUEST_TIMEOUT_MS=30000
LEAD_SCORE_THRESHOLD=0.7

# Queue & Storage Keys
QUEUE_NAME=gtm:posts:queue
QUEUE_PROCESSING_NAME=gtm:posts:processing
QUEUE_DLQ_NAME=gtm:posts:dlq
PROCESSED_URLS_KEY=gtm:processed_urls

# Worker
WORKER_POLL_TIMEOUT_SECONDS=20
WORKER_REQUEUE_STALE_ON_STARTUP=true
