DATABASE_URL=postgresql://user:password@localhost:5432/gtm_crawler
REDIS_URL=redis://localhost:6379

CRAWLER_MAX_CRAWL_DEPTH=5
CRAWLER_MAX_REQUESTS_PER_MINUTE=20
CRAWLER_SAME_DOMAIN_DELAY_SECONDS=3
CRAWLER_MAX_CONCURRENCY=1
CRAWLER_REQUEST_TIMEOUT_MS=60000
CRAWLER_NAVIGATION_TIMEOUT_MS=30000

# Optional: crawler will stop after this many requests
CRAWLER_MAX_REQUESTS_PER_CRAWL=100

# Optional: comma-separated list of proxy URLs
# Example: http://proxy1.example.com:8080,http://proxy2.example.com:8080
#CRAWLER_PROXY_URLS=

CRAWLER_SUBREDDIT_STOP_ON_DUPLICATE=true
