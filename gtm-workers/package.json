{
  "name": "gtm-workers",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "api": "bun run src/bin/api.ts",
    "worker": "bun run src/bin/worker.ts",
    "build": "bun build src/bin/api.ts src/bin/worker.ts --outdir dist --target bun --packages external",
    "typecheck": "bunx tsc --noEmit",
    "docker:up": "docker compose -f docker-compose.test.yml up --detach",
    "docker:down": "docker compose -f docker-compose.test.yml down",
    "test": "bun run docker:up && wait-on tcp:5342 && wait-on tcp:4111 && bun test && bun run docker:down",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bun run src/storage/migrate.ts"
  },
  "dependencies": {
    "apify-client": "^2.22.3",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.10"
  }
}
